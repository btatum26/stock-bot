{
    "features": [
        {
            "id": "RSI",
            "params": {
                "period": 14,
                "overbought": 70.0,
                "oversold": 30.0,
                "normalize": "none"
            }
        },
        {
            "id": "Fractals",
            "params": {
                "fractal_n": 4,
                "source_col": ""
            }
        },
        {
            "id": "SupportResistance",
            "params": {
                "method": "Bill Williams",
                "threshold_pct": 0.015,
                "window": 35,
                "clustering_pct": 0.3,
                "min_strength": 3.0
            }
        }
    ],
    "hyperparameters": {
        "low_vol_threshold": 0.25,
        "high_vol_threshold": 0.75,
        "atr_lookback": 252,
        "atr_roc_max": 0.1,
        "stop_loss": 0.07
    },
    "parameter_bounds": {
        "fractal_n": [
            3,
            5,
            8
        ]
    },
    "compression_mode": "clip",
    "training": {
        "n_groups": 10,
        "k_test_groups": 3
    }
}